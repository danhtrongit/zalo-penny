# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (Postgres)
DATABASE_URL=postgresql://user:pass@localhost:5432/penny

# Auth — MUST be a strong random string in production (>= 32 chars)
JWT_SECRET=replace-with-a-strong-random-secret

# AI provider (YeScale / Gemini proxy)
YESCALE_API_KEY=

# Payment (SePay)
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=
SEPAY_ENV=sandbox

# Frontend
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allowed CORS origins (falls back to FRONTEND_URL when unset)
CORS_ORIGINS=http://localhost:5173

# Zalo bot
# Set to "webhook" if you have a public HTTPS URL, otherwise "polling"
ZALO_BOT_MODE=webhook
ZALO_WEBHOOK_BASE_URL=https://your-public-host.example.com
ZALO_WEBHOOK_SECRET=replace-with-random-secret

# Rate limiting (per-IP, applied to /auth and /payments)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
