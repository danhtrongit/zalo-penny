# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (Postgres)
DATABASE_URL=postgresql://user:pass@localhost:5432/penny

# Auth — MUST be a strong random string in production (>= 32 chars)
JWT_SECRET=replace-with-a-strong-random-secret

# AI provider (YeScale / Gemini proxy)
YESCALE_API_KEY=
# Model served via the YeScale proxy. Default gemini-2.5-flash-lite.
# NOTE: the model must be one your YESCALE_API_KEY has access to — a key
# without access returns HTTP 400 for every request (silent: bot stops replying).
GEMINI_MODEL=gemini-2.5-flash-lite

# Payment (SePay)
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=
SEPAY_ENV=sandbox

# Frontend
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allowed CORS origins (falls back to FRONTEND_URL when unset).
# MUST include every SPA origin that calls this API — including the admin portal.
# Browsers attach an Origin header to non-GET requests even when same-origin via an
# nginx /api proxy, so admin.pennybot.vn must be listed or its POST/PATCH/DELETE 500.
# Prod example: https://pennybot.vn,https://www.pennybot.vn,https://admin.pennybot.vn
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Zalo bot
# Set to "webhook" if you have a public HTTPS URL, otherwise "polling"
ZALO_BOT_MODE=webhook
ZALO_WEBHOOK_BASE_URL=https://your-public-host.example.com
ZALO_WEBHOOK_SECRET=replace-with-random-secret

# Rate limiting (per-IP, applied to /auth and /payments)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Redis (optional). Set this when running multi-instance — message dedup
# uses SETNX so duplicate Zalo retries are rejected cluster-wide.
# Without REDIS_URL the dedup falls back to in-memory (single-instance only).
# REDIS_URL=redis://localhost:6379

# Sentry (optional). When set, unhandled errors, uncaughtException, and
# unhandledRejection are reported with the current request id as trace context.
# SENTRY_DSN=https://your-key@oXXX.ingest.sentry.io/YYY
# SENTRY_TRACES_SAMPLE_RATE=0.1   # 0..1, default 0.1
# SENTRY_PROFILES_SAMPLE_RATE=0   # 0..1, default 0 (profiling is opt-in)
