generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum SubStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PayStatus {
  PENDING
  PAID
  FAILED
}

enum SubscriptionAuditReason {
  REPLACED
  CANCELLED
  EXPIRED
  REFUNDED
  ADMIN_REMOVED
  OTHER
}

enum TxSource {
  TEXT
  IMAGE
  PDF
}

enum BudgetType {
  WEEKLY
  MONTHLY
}

enum PersonaStyle {
  FRIEND
  ASSISTANT
  HOMEMAKER
  COACH
  COMEDIAN
}

enum AdminAction {
  USER_LOCK
  USER_UNLOCK
  USER_ROLE_CHANGE
  PLAN_CREATE
  PLAN_UPDATE
  PLAN_DELETE
  SUBSCRIPTION_MANUAL_UPGRADE
  SUBSCRIPTION_CANCEL
  NOTIFICATION_BROADCAST
  BOT_CREATE
  BOT_UPDATE
  BOT_DELETE
  USER_DELETE
}

enum BotKind {
  OWNED
  POOL
}

enum AssignmentStatus {
  PENDING_LINK
  LINKED
}

model User {
  id           String   @id @default(cuid())
  email        String?
  passwordHash String
  name         String
  phone        String   @unique
  role         Role     @default(USER)
  isLocked     Boolean  @default(false)
  lockedAt     DateTime?
  lockedReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscription  Subscription?
  botConfig     BotConfig?
  botAssignment BotAssignment?
  transactions  Transaction[]
  budgets       Budget[]
  receipts      Receipt[]
  persona       Persona?
  adminActions  AdminAuditLog[] @relation("AdminActor")
}

model Plan {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  durationDays Int
  price        Int
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id            String    @id @default(cuid())
  userId        String    @unique
  planId        String
  status        SubStatus @default(PENDING)
  startDate     DateTime?
  endDate       DateTime?
  invoiceNumber String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  plan    Plan     @relation(fields: [planId], references: [id])
  payment Payment?
}

model Payment {
  id             String    @id @default(cuid())
  subscriptionId String    @unique
  amount         Int
  method         String?
  transactionId  String?
  status         PayStatus @default(PENDING)
  paidAt         DateTime?
  rawResponse    Json?
  createdAt      DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}

model BotConfig {
  id          String    @id @default(cuid())
  userId      String?   @unique
  kind        BotKind   @default(OWNED)
  label       String?
  botToken    String
  botLink     String?
  qrImageUrl  String?
  capacity    Int       @default(5)
  isActive    Boolean   @default(false)
  connectedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User?           @relation(fields: [userId], references: [id])
  assignments BotAssignment[]

  @@index([kind, isActive])
}

model BotAssignment {
  id               String           @id @default(cuid())
  botConfigId      String
  userId           String           @unique
  status           AssignmentStatus @default(PENDING_LINK)
  linkCode         String           @unique
  linkedZaloUserId String?
  createdAt        DateTime         @default(now())
  linkedAt         DateTime?

  botConfig BotConfig @relation(fields: [botConfigId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([botConfigId])
  @@index([status])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  description String
  category    String
  date        DateTime @default(now())
  source      TxSource @default(TEXT)
  receiptId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  receipt Receipt? @relation(fields: [receiptId], references: [id])
}

model Budget {
  id        String     @id @default(cuid())
  userId    String
  type      BudgetType
  amount    Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model Receipt {
  id        String   @id @default(cuid())
  userId    String
  fileUrl   String
  fileType  String
  hash      String?
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model Persona {
  id          String       @id @default(cuid())
  userId      String       @unique
  style       PersonaStyle @default(FRIEND)
  tease       Int          @default(3)
  serious     Int          @default(3)
  frugal      Int          @default(3)
  emoji       Int          @default(3)
  displayName String?
  gender      String?

  user User @relation(fields: [userId], references: [id])
}

model ZaloUser {
  id          String   @id @default(cuid())
  zaloUserId  String
  botConfigId String
  userId      String
  displayName String?
  isOnboarded Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([zaloUserId, botConfigId])
}

model ConversationState {
  id            String   @id @default(cuid())
  zaloUserId    String
  botConfigId   String
  state         Json     @default("{}")
  lastMessageAt DateTime @default(now())

  @@unique([zaloUserId, botConfigId])
}

model SubscriptionAudit {
  id                    String                  @id @default(cuid())
  // Snapshot of the original subscription. We do NOT FK back to Subscription
  // because the source row is deleted at archive time.
  originalSubscriptionId String
  userId                String
  planId                String
  invoiceNumber         String
  status                SubStatus
  startDate             DateTime?
  endDate               DateTime?
  // Payment snapshot
  paymentStatus         PayStatus?
  paymentMethod         String?
  paymentTransactionId  String?
  paymentPaidAt         DateTime?
  paymentAmount         Int?
  paymentRawResponse    Json?
  // Original create time of the subscription row that's being archived
  originalCreatedAt     DateTime
  // Why this row was archived
  reason                SubscriptionAuditReason
  notes                 String?
  archivedAt            DateTime                @default(now())

  @@index([userId])
  @@index([originalSubscriptionId])
  @@index([invoiceNumber])
}

model AdminAuditLog {
  id           String      @id @default(cuid())
  adminId      String
  action       AdminAction
  payload      Json
  summary      String?
  createdAt    DateTime    @default(now())

  admin User @relation("AdminActor", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

enum ReminderKind {
  MORNING
  EVENING
}

model ReminderLog {
  id        String       @id @default(cuid())
  userId    String
  kind      ReminderKind
  sentOn    DateTime
  createdAt DateTime     @default(now())

  @@unique([userId, kind, sentOn])
  @@index([sentOn])
}

model DailyUsage {
  id              String    @id @default(cuid())
  userId          String
  date            DateTime
  count           Int       @default(0)
  limitNotifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, date])
  @@index([date])
}
